      "text": "%spark.pyspark\nwindow_spec = Window.partitionBy(\"city\").orderBy(F.col(\"revenue_sum\").desc())\nranked = aggregated.withColumn(\"rn\", F.row_number().over(window_spec))\ntop2 = ranked.filter(F.col(\"rn\") <= 2).drop(\"rn\")\ntop2.show()",
