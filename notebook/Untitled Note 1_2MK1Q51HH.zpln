    {
      "text": "%spark.pyspark\norders_with_revenue = orders.withColumn(\"revenue\", F.col(\"qty\") * F.col(\"price\"))\norders_with_city = orders_with_revenue.join(users, on=\"user_id\", how=\"inner\")\nfull_data = orders_with_city.join(products, on=\"product_id\", how=\"inner\")\nfull_data.show()",
